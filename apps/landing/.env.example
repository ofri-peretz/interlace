# =============================================================================
# Interlace landing — local environment template
# =============================================================================
# Copy to `.env.local` (gitignored) and fill in real values for local dev.
#
# In CI / production these same variables live as Vercel project env vars
# (Project → Settings → Environment Variables, marked "Sensitive").
# Never commit `.env.local` or any other file with real values.
#
# Source-of-truth checklist for adding a new env var:
#   1. Add it here with a stub value + 1-line description.
#   2. Set the real value in Vercel for the right targets (preview / production).
#   3. Reference it in code as `process.env.<NAME>`; for browser-readable
#      values, prefix with `NEXT_PUBLIC_`.
#   4. Restart `next dev` after editing `.env.local`.
# =============================================================================

# PostHog product analytics. PUBLIC project key (safe to ship in client bundle).
# Get from: https://us.posthog.com/project/<id>/settings/project#variables
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
