{
  "name": "@interlace/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prestorybook": "node scripts/clean-stale-cache.mjs",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "node scripts/clean-stale-cache.mjs",
    "build-storybook": "storybook build -o storybook-static",
    "test": "vitest run",
    "test-storybook": "test-storybook --config-dir .storybook --url http://localhost:6006",
    "test-storybook:ci": "concurrently -k -s first -n SB,TEST \"http-server storybook-static -p 6006 -s\" \"wait-on tcp:6006 && test-storybook --config-dir .storybook --url http://localhost:6006\""
  },
  "dependencies": {
    "@interlace/ui": "*",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-ui": "^16.8.7",
    "lucide-react": "^1.16.0",
    "posthog-js": "^1.207.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.1.2",
    "http-server": "^14.1.1",
    "playwright": "^1.49.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
