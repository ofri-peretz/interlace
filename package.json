{
  "name": "interlace",
  "version": "1.0.0",
  "description": "The Interlace community: design system (@interlace/ui), Storybook (storybook.interlace.tools), and the interlace.tools landing page.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.2",
  "homepage": "https://interlace.tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofri-peretz/interlace.git"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/interlace/issues"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "[ -d .git ] && lefthook install || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "ci:local": "lefthook run pre-push --all-files --force"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-plugin-browser-security": "^1.2.3",
    "eslint-plugin-conventions": "^4.0.7",
    "eslint-plugin-import-next": "^2.3.6",
    "eslint-plugin-maintainability": "^3.0.3",
    "eslint-plugin-modernization": "^2.0.4",
    "eslint-plugin-modularity": "^2.0.4",
    "eslint-plugin-node-security": "^4.2.0",
    "eslint-plugin-operability": "^3.0.6",
    "eslint-plugin-react-a11y": "^2.1.5",
    "eslint-plugin-react-features": "^1.1.4",
    "eslint-plugin-reliability": "^3.1.3",
    "eslint-plugin-secure-coding": "^3.2.0",
    "lefthook": "^1.7.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.9.0",
    "typescript": "^5.7.0"
  }
}
